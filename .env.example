EVOLIZ_PUBLIC_KEY=your_public_key_here
EVOLIZ_SECRET_KEY=your_secret_key_here
# Optionnel : auto-découvert depuis /api/login (ou /api/v1/companies en fallback).
# Ne le préciser que si vous gérez plusieurs sociétés sur le même compte.
# EVOLIZ_COMPANY_ID=12345
# Optionnel : URLs (par défaut prod Evoliz)
# EVOLIZ_BASE_URL=https://www.evoliz.io/api/v1
# EVOLIZ_LOGIN_URL=https://www.evoliz.io/api/login
